  "@id": "omnipath-adapter",
  "name": "OmniPath Adapter",
  "description": "Adapter that produces a knowledge graph of OmniPath secondary interactions for use with BioCypher.",
  "version": "1.0.0",
  "license": "MIT",
  "codeRepository": "https://github.com/biocypher/omnipath-secondary-adapter",
  "programmingLanguage": "Python",
  "targetProduct": "BioCypher",
  "creator": [
    {
      "@type": "Person",
      "name": "Edwin Carre\u00f1o",
      "affiliation": "Scientific Software Center, Saezlab",
      "identifier": "https://orcid.org/0009-0005-3359-2211"
    },
    {
      "@type": "Person",
      "name": "Matthieu Najm",
      "affiliation": "Institute Pasteur",
      "identifier": "https://orcid.org/0000-0001-9757-1499"
    }
  ],
  "keywords": [
    "knowledge-graphs",
    "biocypher",
    "omnipath-secondary-adapter"
  ],
