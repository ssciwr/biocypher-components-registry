{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://biocypher.org/registry/schema/croissant/v1",
  "title": "BioCypher Adapter Croissant Schema v1",
  "description": "Validation schema for BioCypher adapter metadata files (croissant.jsonld). Root is a SoftwareSourceCode wrapping one or more Datasets via hasPart.",
  "type": "object",
  "required": [
    "@type",
    "name",
    "description",
    "version",
    "license",
    "codeRepository",
    "creator",
    "keywords",
    "hasPart"
  ],
  "properties": {
    "@type": {
      "description": "Must be SoftwareSourceCode for the adapter root.",
      "type": "string",
      "const": "SoftwareSourceCode"
    },
    "name": {
      "description": "Canonical name of the adapter.",
      "type": "string",
      "minLength": 1
    },
    "description": {
      "description": "Short summary of the adapter's function and scope.",
      "type": "string",
      "minLength": 1
    },
    "version": {
      "description": "Semantic version or release identifier.",
      "type": "string",
      "minLength": 1
    },
    "license": {
      "description": "License URL or SPDX identifier for the adapter source code.",
      "type": "string",
      "minLength": 1
    },
    "codeRepository": {
      "description": "URL of the adapter code repository.",
      "type": "string",
      "minLength": 1
    },
    "creator": {
      "description": "One or more developers / maintainers of the adapter.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "@type": { "type": "string" },
          "name": { "type": "string", "minLength": 1 },
          "affiliation": { "type": "string" },
          "identifier": {
            "description": "ORCID or other persistent identifier.",
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "keywords": {
      "description": "Tags for discoverability (domain, technology, etc.).",
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "hasPart": {
      "description": "One or more datasets integrated by this adapter.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description", "version", "license", "url"],
        "properties": {
          "@type": { "type": "string" },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "license": {
            "description": "License URL or SPDX identifier for the dataset.",
            "type": "string",
            "minLength": 1
          },
          "url": {
            "description": "URL to the dataset resource.",
            "type": "string",
            "minLength": 1
          },
          "datePublished": { "type": "string" },
          "citeAs": {
            "description": "DOI or citation string for the dataset.",
            "type": "string"
          },
          "creator": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "@type": { "type": "string" },
                "name": { "type": "string", "minLength": 1 },
                "affiliation": { "type": "string" },
                "identifier": { "type": "string" }
              },
              "additionalProperties": true
            }
          },
          "distribution": { "type": "array" },
          "recordSet": { "type": "array" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
