      "@type": "sc:Dataset",
      "dct:conformsTo": "http://mlcommons.org/croissant/1.0",
      "name": "CollecTRI",
      "description": "CollecTRI dataset containing transcription factor regulatory interactions, integrating multi-omics and regulatory interaction data for standardized graph-based analysis.",
      "version": "0.0.1",
      "license": "https://opensource.org/licenses/MIT",
      "url": "https://github.com/biocypher/collectri",
      "keywords": [
        "multi-omics",
        "regulatory interactions"
      ],
      "datePublished": "2024-05-12",
      "creator": [
        {
          "@type": "sc:Person",
          "name": "Sebastian Lobentanzer",
          "affiliation": "Helmholtz Munich",
          "identifier": "https://orcid.org/0000-0003-3399-6695"
        }
